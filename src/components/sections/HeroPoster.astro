---
import GradientField from "@/components/visual/GradientField.astro";
---

<section class="relative isolate overflow-hidden bg-surface-strong px-5 py-28 text-surface-strong-foreground full-bleed lg:py-36">
  <GradientField intensity="strong" />
  <div class="mx-auto max-w-6xl">
    <p class="text-sm font-semibold uppercase tracking-[0.28em] text-white/60">Poster Hero</p>
    <h1 class="font-heading mt-8 max-w-5xl text-6xl leading-[0.88] font-semibold tracking-tight sm:text-8xl lg:text-9xl">
      Gross, klar, nicht brav.
    </h1>
    <div class="mt-10 grid gap-8 md:grid-cols-[.8fr_1.2fr] md:items-start">
      <div class="bg-white/10 h-1 rounded-full"></div>
      <p class="max-w-2xl text-xl leading-relaxed text-white/75">
        Fuer Kampagnen, Events und mutige Produktseiten. Der visuelle Pepp kommt aus Massstab, Kontrast und einem starken Motiv.
      </p>
    </div>
  </div>
</section>
