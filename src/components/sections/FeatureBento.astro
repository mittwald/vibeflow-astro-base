---
import { Icon } from "astro-icon/components";

const items = [
  {
    icon: "lucide:home",
    title: "Privatgaerten",
    text: "Pflege, Rueckschnitt und kleine Umgestaltungen fuer gepflegte Aussenbereiche.",
    className: "bg-primary-soft text-primary-soft-foreground md:col-span-2",
  },
  {
    icon: "lucide:building-2",
    title: "Gewerbeflaechen",
    text: "Regelmaessige Pflege fuer sichtbare Eingangsbereiche und Aussenflaechen.",
    className: "bg-card border-border border",
  },
  {
    icon: "lucide:route",
    title: "Wege & Flaechen",
    text: "Pflaster, Kanten und robuste Wege mit klarer Nutzung.",
    className: "bg-surface-strong text-surface-strong-foreground",
  },
];
---

<section class="px-5 py-20">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-4 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="bg-surface-tint rounded-4xl p-8 md:p-10">
        <p class="text-primary text-sm font-semibold uppercase tracking-[0.22em]">Mosaic statt Standard-Bento</p>
        <h2 class="font-heading mt-5 text-4xl leading-tight font-semibold tracking-tight sm:text-5xl">
          Ein Bento nur dann, wenn es die Inhalte sortiert.
        </h2>
        <p class="text-muted-foreground mt-5 leading-relaxed">
          Fuer lokale Unternehmen wirkt ein ruhiges Leistungs-Mosaic oft glaubwuerdiger als ein Tech-Dashboard-Grid.
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {items.map((item, index) => (
          <article class:list={["rounded-4xl p-7", item.className, index === 0 && "md:min-h-56"]}>
            <Icon name={item.icon} class="h-6 w-6 opacity-80" />
            <h3 class="font-heading mt-7 text-2xl font-semibold tracking-tight">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed opacity-75">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
