---
const steps = [
  ["01", "Kurz anfragen", "Sie senden Adresse, Wunschleistung und optional ein Foto."],
  ["02", "Vor Ort klaeren", "Wir pruefen Umfang, Aufwand und realistischen Termin direkt am Objekt."],
  ["03", "Sauber umsetzen", "Nach Freigabe wird gearbeitet, aufgeraeumt und gemeinsam abgenommen."],
];
---

<section id="ablauf" class="px-5 py-20 lg:py-28">
  <div class="mx-auto max-w-3xl">
    <p class="text-primary text-sm font-semibold uppercase tracking-[0.24em]">Ablauf</p>
    <h2 class="font-heading mt-4 text-4xl leading-tight font-semibold tracking-tight sm:text-6xl">
      Erst klaeren. Dann sauber machen.
    </h2>
    <div class="mt-12 space-y-8">
      {steps.map(([number, title, text]) => (
        <article class="grid gap-5 sm:grid-cols-[5rem_1fr]">
          <p class="text-primary font-heading text-4xl font-semibold">{number}</p>
          <div class="border-border border-b pb-8">
            <h3 class="font-heading text-2xl font-semibold tracking-tight">{title}</h3>
            <p class="text-muted-foreground mt-3 leading-relaxed">{text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
