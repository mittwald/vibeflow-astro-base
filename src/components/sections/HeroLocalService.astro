---
import { Icon } from "astro-icon/components";
import GradientField from "@/components/visual/GradientField.astro";
import VisualMotif from "@/components/visual/VisualMotif.astro";
import { config } from "@/config";
---

<section class="relative overflow-hidden px-5 pt-16 pb-20 sm:pt-20 lg:pb-24">
  <GradientField intensity="quiet" />
  <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="max-w-2xl">
      <p class="text-primary text-sm font-semibold uppercase tracking-[0.22em]">{config.business.serviceArea}</p>
      <h1 class="font-heading mt-5 text-5xl leading-[0.98] font-semibold tracking-tight text-balance sm:text-6xl lg:text-7xl">
        Draussen soll es gut aussehen. Und zuverlaessig erledigt werden.
      </h1>
      <p class="text-muted-foreground mt-6 max-w-xl text-lg leading-relaxed sm:text-xl">
        Pflege, Pflasterarbeiten und Aussenanlagen fuer Menschen, die klare Absprachen, saubere Arbeit und einen festen Ansprechpartner wollen.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href={config.navigation.cta.href} class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex justify-center rounded-full px-6 py-3 text-sm font-semibold transition-colors shadow-lg shadow-primary/20">
          {config.navigation.cta.label}
        </a>
        <a href="#leistungen" class="border-border bg-background/75 hover:bg-background inline-flex justify-center rounded-full border px-6 py-3 text-sm font-semibold transition-colors backdrop-blur">
          Leistungen ansehen
        </a>
      </div>
      <dl class="mt-10 grid max-w-lg grid-cols-3 gap-5 border-y py-5 text-sm">
        <div>
          <dt class="text-muted-foreground">Rueckmeldung</dt>
          <dd class="font-heading mt-1 text-xl font-semibold">24h</dd>
        </div>
        <div>
          <dt class="text-muted-foreground">Region</dt>
          <dd class="font-heading mt-1 text-xl font-semibold">30 km</dd>
        </div>
        <div>
          <dt class="text-muted-foreground">Vor Ort</dt>
          <dd class="font-heading mt-1 text-xl font-semibold">fix</dd>
        </div>
      </dl>
    </div>

    <div class="relative lg:ml-auto">
      <VisualMotif kind="ribbons" class="absolute -right-10 -bottom-10 -z-10 h-80 w-80 opacity-90" />
      <div class="bg-surface-tint border-border relative overflow-hidden rounded-4xl border p-5 shadow-2xl shadow-black/10">
        <div class="bg-surface-strong text-surface-strong-foreground rounded-3xl p-7 sm:p-9">
          <div class="flex items-start justify-between gap-6">
            <div>
              <p class="text-sm uppercase tracking-[0.22em] text-surface-strong-foreground/55">Heute moeglich</p>
              <h2 class="font-heading mt-4 max-w-sm text-4xl leading-tight font-semibold tracking-tight">
                Ersttermin, Pflegeplan oder Angebot.
              </h2>
            </div>
            <span class="bg-primary text-primary-foreground inline-flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl">
              <Icon name="lucide:leaf" class="h-6 w-6" />
            </span>
          </div>
          <div class="mt-10 grid gap-3 sm:grid-cols-2">
            <div class="rounded-3xl bg-white/10 p-5">
              <p class="text-3xl font-semibold">01</p>
              <p class="mt-4 text-sm leading-relaxed text-surface-strong-foreground/70">Kurze Anfrage mit Adresse und Wunschleistung.</p>
            </div>
            <div class="rounded-3xl bg-white/15 p-5 sm:translate-y-6">
              <p class="text-3xl font-semibold">02</p>
              <p class="mt-4 text-sm leading-relaxed text-surface-strong-foreground/70">Rueckruf, Termin und klare Einschaetzung.</p>
            </div>
          </div>
        </div>
        <div class="mt-4 grid grid-cols-[1.3fr_.7fr] gap-4">
          <div class="bg-card rounded-3xl p-5">
            <p class="text-muted-foreground text-sm">Naechste freie Besichtigung</p>
            <p class="font-heading mt-2 text-2xl font-semibold">Diese Woche</p>
          </div>
          <div class="bg-accent-2 text-accent-2-foreground rounded-3xl p-5">
            <p class="text-sm font-medium opacity-70">Gebiet</p>
            <p class="font-heading mt-8 text-xl font-semibold">lokal</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
