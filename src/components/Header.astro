---
import { config } from "@/config";
import { MobileNav } from "@/components/MobileNav";

const { name, navigation } = config;
const links = navigation.header;
---

<header class="border-b border-border">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
    <a href="/" class="text-lg font-semibold">{name}</a>

    <div class="flex items-center gap-6">
      {/* Desktop */}
      {links.length > 0 && (
        <ul class="hidden md:flex items-center gap-6">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      )}

      {/* Mobile */}
      <MobileNav links={links} name={name} client:load />
    </div>
  </nav>
</header>
