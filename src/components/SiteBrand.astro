---
import { config } from "@/config";
import { Icon } from "astro-icon/components";

const logoIcon = config.design.logoIcon ?? "lucide:sparkles";
const className = Astro.props.class ?? "";
---

<a href="/" class:list={["flex items-center gap-3 text-base font-semibold", className]} aria-label="Startseite">
  <span class="bg-primary text-primary-foreground inline-flex h-9 w-9 items-center justify-center rounded-2xl">
    <Icon name={logoIcon} class="h-4 w-4" />
  </span>
  <span class="font-heading tracking-tight">{config.name}</span>
</a>
