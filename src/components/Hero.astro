---
import { Button } from "@/components/ui/button";
import { Icon } from "astro-icon/components";

interface Props {
  badge?: string;
  headline: string;
  headlineAccent: string;
  description: string;
  phone?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  rating?: { score: string; count: string };
}

const {
  badge,
  headline,
  headlineAccent,
  description,
  phone,
  primaryCta,
  secondaryCta,
  rating,
} = Astro.props;
---

<section class="mx-auto max-w-3xl px-4 py-20 text-center sm:py-28 lg:py-32">
  {
    badge && (
      <p class="text-muted-foreground mb-5 text-sm font-medium">{badge}</p>
    )
  }

  <h1
    class="text-foreground text-4xl leading-tight font-bold tracking-tight sm:text-5xl lg:text-6xl"
  >
    {headline}
    {" "}<span class="text-primary">{headlineAccent}</span>
  </h1>

  <p
    class="text-muted-foreground mx-auto mt-5 max-w-xl text-base leading-relaxed sm:text-lg"
  >
    {description}
  </p>

  {
    phone && (
      <a
        href={`tel:${phone.replace(/\s/g, "")}`}
        class="text-foreground hover:text-primary mt-8 inline-flex items-center gap-2.5 text-2xl font-semibold transition-colors"
      >
        <Icon name="lucide:phone" class="text-primary h-5 w-5" />
        {phone}
      </a>
    )
  }

  {
    (primaryCta || secondaryCta) && (
      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        {primaryCta && (
          <a href={primaryCta.href}>
            <Button size="lg" className="h-11 px-8 text-base font-semibold">
              {primaryCta.label}
            </Button>
          </a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href}>
            <Button variant="outline" size="lg" className="h-11 px-8 text-base">
              {secondaryCta.label}
            </Button>
          </a>
        )}
      </div>
    )
  }

  {
    rating && (
      <div class="mt-8 flex items-center justify-center gap-2">
        <div class="flex">
          {Array.from({ length: 5 }).map(() => (
            <Icon
              name="lucide:star"
              class="h-4 w-4 fill-amber-400 text-amber-400"
            />
          ))}
        </div>
        <span class="text-foreground text-sm font-medium">{rating.score}</span>
        <span class="text-muted-foreground text-sm">
          · {rating.count} Bewertungen
        </span>
      </div>
    )
  }
</section>
