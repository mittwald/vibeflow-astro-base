---
interface Item { question: string; answer: string }
interface Props {
  eyebrow?: string;
  headline: string;
  items: readonly Item[];
}

const { eyebrow, headline, items } = Astro.props;
---

<section data-section="content" data-block-family="faq-accordion" class="scroll-mt-32 px-5 py-20">
  <div class="mx-auto max-w-4xl">
    {eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">{eyebrow}</p>}
    <h2 class="mt-5 font-heading text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">{headline}</h2>
    <div class="mt-10 divide-y divide-border border-y border-border">
      {items.map((item) => (
        <details class="group py-5">
          <summary class="cursor-pointer list-none font-heading text-xl font-semibold tracking-tight marker:hidden">
            {item.question}
          </summary>
          <p class="mt-3 leading-relaxed text-muted-foreground">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
