---
interface Link { label: string; href: string }
interface Detail { label: string; value: string; href?: string }
interface Props {
  eyebrow?: string;
  headline: string;
  text?: string;
  details?: readonly Detail[];
  cta?: Link;
}

const { eyebrow, headline, text, details = [], cta } = Astro.props;
---

<section id="kontakt" data-section="contact" data-block-family="contact-split-local" class="scroll-mt-32 px-5 py-20 lg:py-28">
  <div class="mx-auto grid max-w-6xl gap-10 border border-border bg-card p-8 md:grid-cols-[0.9fr_1.1fr] md:p-12">
    <div>
      {eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">{eyebrow}</p>}
      <h2 class="mt-5 font-heading text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">{headline}</h2>
      {text && <p class="mt-5 leading-relaxed text-muted-foreground">{text}</p>}
      {cta && <a href={cta.href} class="mt-8 inline-flex min-h-12 items-center rounded-full bg-primary px-5 text-sm font-semibold text-primary-foreground">{cta.label}</a>}
    </div>

    {details.length > 0 && (
      <dl class="divide-y divide-border border-y border-border">
        {details.map((detail) => (
          <div class="grid gap-2 py-5 sm:grid-cols-[9rem_1fr]">
            <dt class="text-sm font-semibold uppercase tracking-[0.18em] text-muted-foreground">{detail.label}</dt>
            <dd class="font-medium">
              {detail.href ? <a href={detail.href} class="hover:text-primary">{detail.value}</a> : detail.value}
            </dd>
          </div>
        ))}
      </dl>
    )}
  </div>
</section>
