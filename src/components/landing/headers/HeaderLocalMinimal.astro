---
interface NavLink { label: string; href: string }
interface Props {
  name: string;
  links?: readonly NavLink[];
  cta?: NavLink;
}

const { name, links = [], cta } = Astro.props;
---

<header data-section="header" data-block-family="header-local-minimal" class="border-b border-border bg-background">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-4" aria-label="Hauptnavigation">
    <a href="/" class="font-heading text-lg font-semibold tracking-tight">{name}</a>

    {links.length > 0 && (
      <ul class="hidden items-center gap-6 md:flex">
        {links.map((link) => (
          <li><a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">{link.label}</a></li>
        ))}
      </ul>
    )}

    {cta && (
      <a href={cta.href} class="hidden min-h-11 items-center rounded-full bg-primary px-4 text-sm font-semibold text-primary-foreground md:inline-flex">
        {cta.label}
      </a>
    )}
  </nav>
</header>
