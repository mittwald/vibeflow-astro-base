---
interface NavLink { label: string; href: string }
interface Props {
  name: string;
  links?: readonly NavLink[];
  cta?: NavLink;
  phone?: string;
}

const { name, links = [], cta, phone } = Astro.props;
const phoneHref = phone ? `tel:${phone.replace(/[^\d+]/g, "")}` : undefined;
---

<header data-section="header" data-block-family="header-trade-service" class="border-b border-border bg-background">
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-5 px-5 py-4" aria-label="Hauptnavigation">
    <a href="/" class="font-heading text-lg font-semibold tracking-tight">{name}</a>

    {links.length > 0 && (
      <ul class="hidden items-center gap-6 md:flex">
        {links.map((link) => (
          <li><a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">{link.label}</a></li>
        ))}
      </ul>
    )}

    <div class="hidden items-center gap-4 md:flex">
      {phone && phoneHref && <a href={phoneHref} class="text-sm font-semibold text-foreground hover:text-primary">{phone}</a>}
      {cta && <a href={cta.href} class="min-h-11 rounded-full bg-primary px-4 py-3 text-sm font-semibold text-primary-foreground">{cta.label}</a>}
    </div>
  </nav>
</header>
