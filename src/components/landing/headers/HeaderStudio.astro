---
interface NavLink { label: string; href: string }
interface Props {
  name: string;
  links?: readonly NavLink[];
  booking?: NavLink;
}

const { name, links = [], booking } = Astro.props;
---

<header data-section="header" data-block-family="header-studio-booking" class="border-b border-border bg-background">
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-5 px-5 py-5" aria-label="Hauptnavigation">
    <a href="/" class="font-heading text-xl font-semibold tracking-tight">{name}</a>

    {links.length > 0 && (
      <ul class="hidden items-center gap-7 md:flex">
        {links.map((link) => (
          <li><a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">{link.label}</a></li>
        ))}
      </ul>
    )}

    {booking && (
      <a href={booking.href} class="hidden min-h-11 items-center rounded-full bg-foreground px-5 text-sm font-semibold text-background md:inline-flex">
        {booking.label}
      </a>
    )}
  </nav>
</header>
