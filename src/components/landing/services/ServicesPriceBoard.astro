---
interface Offer { title: string; price?: string; text?: string; details?: readonly string[] }
interface Props {
  eyebrow?: string;
  headline: string;
  text?: string;
  offers: readonly Offer[];
}

const { eyebrow, headline, text, offers } = Astro.props;
---

<section id="leistungen" data-section="services" data-block-family="services-price-board" class="scroll-mt-32 bg-surface-tint px-5 py-20 lg:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-3xl">
      {eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">{eyebrow}</p>}
      <h2 class="mt-5 font-heading text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">{headline}</h2>
      {text && <p class="mt-5 leading-relaxed text-muted-foreground">{text}</p>}
    </div>

    <div class="mt-10 grid gap-px bg-border md:grid-cols-3">
      {offers.map((offer) => (
        <article class="bg-background p-7">
          <div class="flex items-start justify-between gap-4">
            <h3 class="font-heading text-2xl font-semibold tracking-tight">{offer.title}</h3>
            {offer.price && <p class="shrink-0 font-semibold text-primary">{offer.price}</p>}
          </div>
          {offer.text && <p class="mt-4 text-sm leading-relaxed text-muted-foreground">{offer.text}</p>}
          {offer.details && offer.details.length > 0 && (
            <ul class="mt-5 space-y-2 text-sm text-muted-foreground">
              {offer.details.map((detail) => <li>+ {detail}</li>)}
            </ul>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
