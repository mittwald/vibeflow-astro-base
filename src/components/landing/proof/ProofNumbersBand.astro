---
interface Metric { value: string; label: string }
interface Props {
  eyebrow?: string;
  headline?: string;
  metrics: readonly Metric[];
}

const { eyebrow, headline, metrics } = Astro.props;
---

<section data-section="proof" data-block-family="proof-numbers-band" class="scroll-mt-32 px-5 py-20">
  <div class="mx-auto max-w-7xl bg-primary-soft p-8 text-primary-soft-foreground md:p-12">
    {(eyebrow || headline) && (
      <div class="mb-10 max-w-2xl">
        {eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.24em] opacity-70">{eyebrow}</p>}
        {headline && <h2 class="mt-4 font-heading text-4xl font-semibold tracking-tight sm:text-5xl">{headline}</h2>}
      </div>
    )}
    <dl class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {metrics.map((metric) => (
        <div>
          <dt class="text-sm leading-relaxed opacity-75">{metric.label}</dt>
          <dd class="mt-2 font-heading text-5xl font-semibold tracking-tight">{metric.value}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
