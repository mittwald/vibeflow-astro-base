---
import { config } from "@/config";
import SiteBrand from "@/components/SiteBrand.astro";

const { name, navigation, tagline, design, business } = config;
const links = navigation.footer;
const variant = design.footer;
const year = new Date().getFullYear();
const phoneHref = business.phone ? `tel:${business.phone.replace(/[^\d+]/g, "")}` : undefined;
---

{variant === "takeover" ? (
  <footer class="full-bleed mt-20 bg-surface-strong text-surface-strong-foreground">
    <div class="mx-auto grid max-w-6xl gap-10 px-5 py-12 md:grid-cols-[1.3fr_.7fr] md:items-end lg:py-16">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-surface-strong-foreground/60">Naechster Schritt</p>
        <h2 class="mt-4 max-w-3xl font-heading text-4xl font-semibold leading-tight tracking-tight md:text-6xl">
          Bereit fuer eine Website mit eigener Struktur.
        </h2>
      </div>
      <div class="md:text-right">
        <a
          href={navigation.cta.href}
          class="inline-flex rounded-full bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90"
        >
          {navigation.cta.label}
        </a>
      </div>
    </div>
    <div class="border-t border-white/10">
      <div class="mx-auto flex max-w-6xl flex-col gap-4 px-5 py-5 text-sm text-white/65 sm:flex-row sm:items-center sm:justify-between">
        <p>&copy; {year} {name} - {tagline}</p>
        {links.length > 0 && (
          <nav aria-label="Footer-Navigation">
            <ul class="flex flex-wrap items-center gap-4 sm:gap-6">
              {links.map((link) => (
                <li><a href={link.href} class="transition-colors hover:text-white">{link.label}</a></li>
              ))}
            </ul>
          </nav>
        )}
      </div>
    </div>
  </footer>
) : variant === "contact-heavy" ? (
  <footer class="full-bleed mt-16 bg-surface-strong text-surface-strong-foreground">
    <div class="mx-auto grid max-w-6xl gap-10 px-5 py-12 md:grid-cols-[1fr_1fr_.7fr] lg:py-16">
      <div>
        <SiteBrand class="text-surface-strong-foreground" />
        <p class="mt-5 max-w-sm text-sm leading-relaxed text-surface-strong-foreground/70">{tagline}</p>
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-surface-strong-foreground/55">Kontakt</p>
        <div class="mt-5 space-y-2 text-sm text-surface-strong-foreground/78">
          {business.address && <p>{business.address}</p>}
          {business.phone && phoneHref && <p><a href={phoneHref} class="transition-colors hover:text-white">{business.phone}</a></p>}
          {business.email && <p><a href={`mailto:${business.email}`} class="transition-colors hover:text-white">{business.email}</a></p>}
          {business.hours && <p>{business.hours}</p>}
        </div>
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-surface-strong-foreground/55">Seiten</p>
        {links.length > 0 && (
          <nav aria-label="Footer-Navigation" class="mt-5">
            <ul class="space-y-2 text-sm text-surface-strong-foreground/78">
              {links.map((link) => (
                <li><a href={link.href} class="transition-colors hover:text-white">{link.label}</a></li>
              ))}
            </ul>
          </nav>
        )}
      </div>
    </div>
    <div class="border-t border-white/10">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 px-5 py-5 text-xs text-surface-strong-foreground/55 sm:flex-row sm:items-center sm:justify-between">
        <p>&copy; {year} {name}</p>
        {business.serviceArea && <p>{business.serviceArea}</p>}
      </div>
    </div>
  </footer>
) : variant === "sitemap" ? (
  <footer class="border-t border-border bg-surface-tint">
    <div class="mx-auto grid max-w-6xl gap-8 px-5 py-10 sm:grid-cols-[1fr_auto]">
      <div>
        <SiteBrand />
        <p class="mt-4 max-w-md text-sm text-muted-foreground">{tagline}</p>
      </div>
      {links.length > 0 && (
        <nav aria-label="Footer-Navigation">
          <ul class="grid gap-2 text-sm sm:grid-cols-2 sm:gap-x-8">
            {links.map((link) => (
              <li><a href={link.href} class="text-muted-foreground transition-colors hover:text-foreground">{link.label}</a></li>
            ))}
          </ul>
        </nav>
      )}
    </div>
  </footer>
) : (
  <footer class="border-t border-border">
    <div class="mx-auto flex max-w-6xl flex-col items-center gap-3 px-5 py-5 sm:flex-row sm:justify-between">
      <p class="text-sm text-muted-foreground">&copy; {year} {name}</p>
      {links.length > 0 && (
        <nav aria-label="Footer-Navigation">
          <ul class="flex flex-wrap items-center justify-center gap-4 sm:gap-6">
            {links.map((link) => (
              <li><a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">{link.label}</a></li>
            ))}
          </ul>
        </nav>
      )}
    </div>
  </footer>
)}
