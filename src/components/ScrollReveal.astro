---
interface Props {
  animation?: "fade-up" | "fade-in" | "fade-left" | "fade-right" | "scale-in";
  delay?: number;
  duration?: number;
  threshold?: number;
  once?: boolean;
  class?: string;
}

const {
  animation = "fade-up",
  delay = 0,
  duration = 600,
  threshold = 0.1,
  once = true,
  class: className,
} = Astro.props;
---

<div
  class:list={["scroll-reveal", className]}
  data-sr-animation={animation}
  data-sr-delay={delay}
  data-sr-duration={duration}
  data-sr-threshold={threshold}
  data-sr-once={once}
>
  <slot />
</div>

<style>
  .scroll-reveal {
    opacity: 0;
    will-change: transform, opacity;
  }

  .scroll-reveal[data-sr-animation="fade-up"] {
    transform: translateY(20px);
  }

  .scroll-reveal[data-sr-animation="fade-in"] {
    transform: none;
  }

  .scroll-reveal[data-sr-animation="fade-left"] {
    transform: translateX(20px);
  }

  .scroll-reveal[data-sr-animation="fade-right"] {
    transform: translateX(-20px);
  }

  .scroll-reveal[data-sr-animation="scale-in"] {
    transform: scale(0.95);
  }

  .scroll-reveal.is-visible {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-reveal {
      opacity: 1;
      transform: none;
      transition: none !important;
    }
  }
</style>

<script>
  function initScrollReveal() {
    const elements = document.querySelectorAll<HTMLElement>(".scroll-reveal");

    if (!elements.length) return;

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (prefersReducedMotion) {
      elements.forEach((el) => el.classList.add("is-visible"));
      return;
    }

    const observed = new Map<Element, IntersectionObserver>();

    elements.forEach((el) => {
      const delay = Number(el.dataset.srDelay) || 0;
      const duration = Number(el.dataset.srDuration) || 600;
      const threshold = Number(el.dataset.srThreshold) || 0.1;
      const once = el.dataset.srOnce !== "false";

      el.style.transition = `opacity ${duration}ms ease-out, transform ${duration}ms ease-out`;
      el.style.transitionDelay = `${delay}ms`;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              if (once) {
                observer.unobserve(entry.target);
                observed.delete(entry.target);
              }
            } else if (!once) {
              entry.target.classList.remove("is-visible");
            }
          });
        },
        { threshold },
      );

      observer.observe(el);
      observed.set(el, observer);
    });
  }

  initScrollReveal();
  document.addEventListener("astro:page-load", initScrollReveal);
</script>
