---
import RootLayout from "@/components/RootLayout.astro";
import { ContactForm } from "@/components/ContactForm";
import { config } from "@/config";
---

<RootLayout title={`Kontakt - ${config.name}`} description="Nimm Kontakt auf und starte dein Website-Projekt.">
  <section class="px-5 pt-32 pb-20 lg:pt-40 lg:pb-28">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="text-primary text-sm font-semibold uppercase tracking-[0.24em]">Kontakt</p>
        <h1 class="font-heading mt-4 text-5xl leading-tight font-semibold tracking-tight sm:text-7xl">
          Kurz beschreiben, was gebaut werden soll.
        </h1>
        <p class="text-muted-foreground mt-6 max-w-xl text-lg leading-relaxed">
          Das Formular bleibt bewusst ruhig und klar. Auf kleinen Screens wechseln die Eingabepaare automatisch auf eine Spalte.
        </p>
      </div>
      <div class="border-border bg-card rounded-4xl border p-5 shadow-sm sm:p-8">
        <ContactForm client:load />
      </div>
    </div>
  </section>
</RootLayout>
