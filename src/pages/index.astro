---
import RootLayout from "@/components/RootLayout.astro";
import { Button } from "@/components/ui/button";
import { Icon } from "astro-icon/components";
import { config } from "@/config";
---

<RootLayout
  title={`${config.name} – ${config.tagline}`}
  description="Ihr zuverlässiger Partner vor Ort — schnell, professionell und zum fairen Preis."
>
  <section class="mx-auto max-w-3xl px-4 py-20 text-center sm:py-28 lg:py-32">
    <h1
      class="text-foreground text-4xl leading-tight font-bold tracking-tight sm:text-5xl lg:text-6xl"
    >
      Ihr zuverlässiger
      {" "}<span class="text-primary">Partner vor Ort.</span>
    </h1>

    <p
      class="text-muted-foreground mx-auto mt-5 max-w-xl text-base leading-relaxed sm:text-lg"
    >
      Professionell, schnell und zum fairen Preis. Nehmen Sie Kontakt auf oder
      vereinbaren Sie direkt einen Termin.
    </p>

    <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
      <a href="/kontakt">
        <Button size="lg" className="h-11 px-8 text-base font-semibold">
          Termin vereinbaren
        </Button>
      </a>
      <a href="#leistungen">
        <Button variant="outline" size="lg" className="h-11 px-8 text-base">
          Mehr erfahren
        </Button>
      </a>
    </div>

    <div class="mt-8 flex items-center justify-center gap-2">
      <div class="flex">
        {
          Array.from({ length: 5 }).map(() => (
            <Icon
              name="lucide:star"
              class="h-4 w-4 fill-primary text-primary"
            />
          ))
        }
      </div>
      <span class="text-foreground text-sm font-medium">4.9</span>
      <span class="text-muted-foreground text-sm">· 100+ Bewertungen</span>
    </div>
  </section>
</RootLayout>
