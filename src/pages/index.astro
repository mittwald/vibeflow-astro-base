---
import RootLayout from "@/components/RootLayout.astro";
import { Button } from "@/components/ui/button";
---

<RootLayout title="vibeflow – dein AI-Website-Builder">
	<main class="flex min-h-screen flex-col items-center justify-center px-4 text-center">
		<svg xmlns="http://www.w3.org/2000/svg" class="mb-6 h-20 w-20 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
			<path d="M12 2L9 9l-7 1 5 5-1.5 7L12 18l6.5 4L17 15l5-5-7-1z" />
			<circle cx="12" cy="11" r="2" fill="currentColor" stroke="none" />
			<path d="M12 2v3M8.5 7.5L6 5.5M15.5 7.5L18 5.5" opacity="0.5" />
		</svg>
		<h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Herzlich willkommen</h1>
		<p class="mt-4 text-lg text-muted-foreground">
			bei <span class="font-semibold">vibeflow</span> – dein AI-Website-Builder
		</p>
		<a href="https://studio.mittwald.de" target="_blank" rel="noopener noreferrer">
			<Button className="mt-8 bg-blue-600 text-white hover:bg-blue-700 px-6 py-3 text-lg">
				Zum mStudio
			</Button>
		</a>
	</main>
</RootLayout>
