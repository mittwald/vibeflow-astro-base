---
import RootLayout from "@/components/RootLayout.astro";
import { Icon } from "astro-icon/components";
import { Button } from "@/components/ui/button";
---

<RootLayout title="vibeflow – dein AI-Website-Builder">
	<div class="flex flex-1 flex-col items-center justify-center px-4 text-center">
		<Icon name="lucide:sparkles" class="mb-6 h-16 w-16 text-blue-600" />
		<h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Herzlich willkommen</h1>
		<p class="mt-4 text-lg text-muted-foreground">
			bei <span class="font-semibold">vibeflow</span> – dein AI-Website-Builder
		</p>
		<a href="https://studio.mittwald.de" target="_blank" rel="noopener noreferrer">
			<Button className="mt-8 bg-blue-600 text-white hover:bg-blue-700 px-6 py-3 text-lg">
				Zum mStudio
			</Button>
		</a>
	</div>
</RootLayout>
