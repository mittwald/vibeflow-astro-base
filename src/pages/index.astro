---
import RootLayout from "@/components/RootLayout.astro";
import Hero from "@/components/Hero.astro";
import { config } from "@/config";
---

<RootLayout
  title={`${config.name} – ${config.tagline}`}
  description="Ihr zuverlässiger Fachbetrieb vor Ort — schnell, professionell und zum fairen Preis."
>
  <Hero
    badge="Meisterbetrieb · Seit 1987"
    headline="Ihr zuverlässiger"
    headlineAccent="Partner vor Ort."
    description="Schnell, professionell und zum fairen Preis — für Privat- und Geschäftskunden in der Region. Rufen Sie uns an oder vereinbaren Sie einen Termin online."
    phone="0123 / 456 78-0"
    primaryCta={{ label: "Termin vereinbaren", href: "/kontakt" }}
    secondaryCta={{ label: "Unsere Leistungen", href: "#leistungen" }}
    rating={{ score: "4.9", count: "127" }}
    stats={[
      { value: "35+", label: "Jahre Erfahrung" },
      { value: "2.400+", label: "zufriedene Kunden" },
      { value: "24h", label: "Notdienst" },
    ]}
  />
</RootLayout>
