---
import RootLayout from "@/components/RootLayout.astro";
import { Icon } from "astro-icon/components";
import { Button } from "@/components/ui/button";
---

<RootLayout title="Seite nicht gefunden">
  <div class="flex flex-1 flex-col items-center justify-center px-4 text-center">
    <Icon name="lucide:search-x" class="mb-6 h-16 w-16 text-muted-foreground" />
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">404</h1>
    <p class="mt-4 text-lg text-muted-foreground">
      Diese Seite wurde nicht gefunden.
    </p>
    <a href="/">
      <Button className="mt-8 px-6 py-3 text-lg">
        Zur Startseite
      </Button>
    </a>
  </div>
</RootLayout>
