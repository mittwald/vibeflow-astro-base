---
import RootLayout from "@/components/RootLayout.astro";
import { Icon } from "astro-icon/components";
import { Button } from "@/components/ui/button";
import { config } from "@/config";
---

<RootLayout title={`Seite nicht gefunden – ${config.name}`}>
  <div
    class="flex flex-1 flex-col items-center justify-center px-4 text-center"
  >
    <Icon name="lucide:search-x" class="text-muted-foreground mb-6 h-16 w-16" />
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">404</h1>
    <p class="text-muted-foreground mt-4 text-lg">
      Diese Seite wurde nicht gefunden.
    </p>
    <a href="/">
      <Button className="mt-8 px-6 py-3 text-lg"> Zur Startseite </Button>
    </a>
  </div>
</RootLayout>
