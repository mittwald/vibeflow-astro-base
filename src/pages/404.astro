---
import RootLayout from "@/components/RootLayout.astro";
import { config } from "@/config";
---

<RootLayout title={`404 - ${config.name}`} description="Diese Seite wurde nicht gefunden.">
  <section class="px-5 pt-32 pb-20 lg:pt-40">
    <div class="mx-auto max-w-3xl">
      <p class="text-primary text-sm font-semibold uppercase tracking-[0.24em]">404</p>
      <h1 class="font-heading mt-4 text-5xl leading-tight font-semibold tracking-tight sm:text-7xl">
        Diese Seite ist nicht da.
      </h1>
      <p class="text-muted-foreground mt-5 text-lg leading-relaxed">
        Der Link ist falsch oder die Seite wurde verschoben.
      </p>
      <a href="/" class="bg-primary text-primary-foreground mt-8 inline-flex rounded-full px-6 py-3 text-sm font-semibold transition-colors hover:bg-primary/90">
        Zur Startseite
      </a>
    </div>
  </section>
</RootLayout>
